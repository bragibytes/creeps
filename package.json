{
  "name": "realm-of-echoes",
  "version": "0.1.0",
  "description": "A classic MMO text adventure for the CLI",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "tsx src/client/index.ts",
    "server": "tsx src/server/index.ts",
    "client": "tsx src/client/index.ts",
    "client:plain": "tsx src/client/index.ts --plain",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "start:server": "node dist/server/index.js",
    "start:client": "node dist/client/index.js"
  },
  "bin": {
    "realm": "dist/client/index.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "neo-blessed": "^0.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
