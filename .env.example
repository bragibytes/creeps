# ── Local dev ──────────────────────────────────────────
PORT=4242
REALM_SERVER=ws://localhost:4242
ADMIN_USERS=your_username_here

# ── Railway (set in dashboard, not all needed locally) ─
# PORT              — injected automatically by Railway
# ADMIN_USERS       — your in-game admin username(s), comma-separated
# DATA_DIR=/data    — if you mount a persistent volume at /data