# Client auto-discovers production URL from /config — no REALM_SERVER needed.
# Override only for local dev or a different server:
# REALM_SERVER=ws://localhost:4242/ws

# ── Local dev server ───────────────────────────────────────────
PORT=4242
ADMIN_USERS=your_username_here

# ── Database (Railway Postgres injects DATABASE_URL automatically) ──
DATABASE_URL=postgres://user:password@localhost:5432/realm

# ── Optional overrides ─────────────────────────────────────────
# REALM_API=unique-transformation-production-44b4.up.railway.app
# WORLD_PATH=data/world.json
# MOTD=Welcome to the Realm of Echoes!